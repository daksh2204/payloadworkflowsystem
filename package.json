{
  "name": "payload-workflow-system",
  "version": "1.0.0",
  "description": "Dynamic Workflow Management System for Payload CMS v2+",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "test": "jest",
    "test:watch": "jest --watch",
    "seed": "cross-env NODE_ENV=development ts-node src/seed.ts"
  },
  "keywords": [
    "payload",
    "cms",
    "workflow",
    "approval",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@payloadcms/bundler-webpack": "^1.0.7",
    "@payloadcms/db-mongodb": "^1.0.0",
    "@payloadcms/richtext-slate": "^1.0.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "payload": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "cross-env": "^7.0.3",
    "fast-check": "^3.15.0",
    "jest": "^29.5.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
